# ─────────────────────────────────────────────────────────────
#  Codexa — .gitignore
#  Next.js (frontend) + FastAPI + SQLite (backend)
# ─────────────────────────────────────────────────────────────


# ── OS & Editor ───────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
*.orig


# ── Environment / Secrets ─────────────────────────────────────
.env
.env.*
!.env.example          # root level (if any)
!**/.env.example       # subdirectory .env.example files (backend/, frontend/)
*.pem
*.key
serviceAccountKey.json
firebase-adminsdk*.json


# ────────────────────────────────────────────────────────────
#  BACKEND  (FastAPI / Python)
# ────────────────────────────────────────────────────────────

# Python cache
_pycache_/
*.py[cod]
*.pyo
*.pyd
.Python

# Virtual environments
backend/venv/
backend/.venv/
venv/
.venv/
env/
.env/

# SQLite database (don't push the actual DB file)
backend/*.db
backend/*.sqlite
backend/*.sqlite3

# Eggs / dist / build
*.egg-info/
dist/
build/
*.egg
.eggs/

# pytest / coverage
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# mypy / ruff / pyright
.mypy_cache/
.ruff_cache/
pyrightconfig.json


# ────────────────────────────────────────────────────────────
#  FRONTEND  (Next.js / Node)
# ────────────────────────────────────────────────────────────

# Dependencies
frontend/node_modules/
node_modules/

# Next.js build output
frontend/.next/
frontend/out/

# Vercel
.vercel/

# TypeScript build info
*.tsbuildinfo
frontend/next-env.d.ts

# Package manager locks (keep only one — we use npm)
# frontend/yarn.lock   # uncomment if you want to ignore yarn.lock
# frontend/pnpm-lock.yaml

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Storybook (if added later)
frontend/storybook-static/


# ── Misc ──────────────────────────────────────────────────────
*.log
*.tmp
*.bak